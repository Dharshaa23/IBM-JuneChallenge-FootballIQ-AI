# --- IBM watsonx.ai / Granite credentials ---
# Leave blank to run FootballIQ AI in offline demo mode (template-based fallback).
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
GRANITE_MODEL_ID=ibm/granite-3-8b-instruct

# --- Live football data provider ---
# Options: sample (default, offline) | api-football | football-data
LIVE_FOOTBALL_PROVIDER=sample
LIVE_FOOTBALL_API_KEY=
